{
  "expo": {
    "name": "Fullstack Mobile",
    "slug": "fullstack-mobile",
    "scheme": "fullstackmobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
      "package": "com.template.fullstackmobile"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
