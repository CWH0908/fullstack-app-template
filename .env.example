# Shared client API endpoints. Each platform reads a different prefix by convention.
TARO_APP_API_BASE_URL=http://localhost:3000
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
VITE_API_BASE_URL=http://localhost:3000

# API service configuration.
API_PORT=3000
DATABASE_URL=mysql://root:password@localhost:3306/fullstack_app
JWT_SECRET=replace-with-a-long-random-secret

# WeChat mini program credentials are intentionally blank in the template.
WECHAT_APP_ID=
WECHAT_APP_SECRET=
